# GEO Pulse single-tenant production example.
# Copy to your deployment environment and replace every placeholder value.

NODE_ENV=production
PORT=3000
GEO_HOST=0.0.0.0
GEO_PUBLIC_SITE_URL=https://geo.example.com

# Required for production. Use a long random value and keep it secret.
GEO_INTERNAL_API_KEY=replace-with-at-least-24-random-characters

# Remote access must be intentional. Keep this disabled unless the service is
# protected by reverse proxy auth, VPN, IP allowlist, or another access layer.
GEO_ALLOW_REMOTE_ACCESS=1

# Persistence
GEO_ENABLE_PERSISTENCE=1
GEO_DATA_FILE=/app/data/geo-pulse-state.json

# Automation scheduler
GEO_ENABLE_AUTOMATION_SCHEDULER=0
GEO_AUTOMATION_TICK_MS=15000
GEO_AUTOMATION_MAX_RUNS_PER_TICK=2
GEO_DEFAULT_INDUSTRY_TOPIC=中国智能体

# Safety limits
GEO_MAX_BODY_BYTES=1048576
GEO_MUTATION_RATE_LIMIT_PER_MINUTE=120
